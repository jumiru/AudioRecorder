<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_2"
    android:layout_marginVertical="@dimen/space_1"
    style="@style/Widget.AudioRecorder.Card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_2">

        <!-- Drag handle -->
        <ImageButton
            android:id="@+id/drag_handle"
            android:layout_width="@dimen/touch_icon_button"
            android:layout_height="@dimen/touch_icon_button"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/drag_handle_desc"
            app:srcCompat="@drawable/ic_drag_handle"
            app:tint="?android:attr/textColorSecondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Name -->
        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/open_player_desc"
            android:textSize="16sp"
            android:textColor="@color/colorOnSurface"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/drag_handle"
            app:layout_constraintEnd_toStartOf="@id/btn_play"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="@dimen/space_1"
            android:layout_marginEnd="@dimen/space_1" />

        <!-- Duration -->
        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/colorOnSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/drag_handle"
            app:layout_constraintEnd_toStartOf="@id/btn_play"
            app:layout_constraintTop_toBottomOf="@id/tv_name"
            android:layout_marginStart="@dimen/space_1"
            android:layout_marginTop="2dp" />

        <!-- Progress bar (playback) -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/drag_handle"
            app:layout_constraintEnd_toStartOf="@id/btn_play"
            app:layout_constraintTop_toBottomOf="@id/tv_duration"
            android:layout_marginStart="@dimen/space_1"
            android:layout_marginTop="@dimen/space_1"
            android:layout_marginBottom="2dp"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Play/Stop button -->
        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="@dimen/touch_icon_button"
            android:layout_height="@dimen/touch_icon_button"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/play_desc"
            app:srcCompat="@drawable/ic_play"
            app:tint="@color/colorPrimary"
            app:layout_constraintEnd_toStartOf="@id/btn_upload"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Upload button -->
        <ImageButton
            android:id="@+id/btn_upload"
            android:layout_width="@dimen/touch_icon_button"
            android:layout_height="@dimen/touch_icon_button"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/upload_desc"
            app:srcCompat="@drawable/ic_upload"
            app:tint="?android:attr/textColorSecondary"
            app:layout_constraintEnd_toStartOf="@id/btn_rename"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Rename button -->
        <ImageButton
            android:id="@+id/btn_rename"
            android:layout_width="@dimen/touch_icon_button"
            android:layout_height="@dimen/touch_icon_button"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/rename_desc"
            app:srcCompat="@drawable/ic_edit"
            app:tint="?android:attr/textColorSecondary"
            app:layout_constraintEnd_toStartOf="@id/btn_delete"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="@dimen/touch_icon_button"
            android:layout_height="@dimen/touch_icon_button"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete_desc"
            app:srcCompat="@drawable/ic_delete"
            app:tint="@color/colorDelete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

